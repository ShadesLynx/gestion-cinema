{% extends 'base.html.twig' %}

{% block title %}Connexion — CinéMax{% endblock %}

{% block extra_css %}
    <style>
        .auth-wrap {
            min-height: 100vh;
            width: 100%;
            display: flex;
            align-items: center;    /* Vertical center */
            justify-content: center; /* Horizontal center */
            box-sizing: border-box;
            /* Remove any left, right, or position:relative here */
        }

        .auth-card {
            background: var(--card);
            border: 1px solid var(--border2);
            border-radius: 16px;
            width: 100%;
            max-width: 440px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,.6);
            /* Ensure no margins are pushing it */
            margin: 0 auto;
        }
        .auth-header {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 2.5rem 2rem 2rem;
            text-align: center;
            border-bottom: 1px solid var(--border2);
        }
        .auth-icon {
            width: 56px; height: 56px; border-radius: 50%;
            background: linear-gradient(135deg, var(--gold), var(--gold-lt));
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1rem;
            font-size: 1.3rem; color: #08080e;
        }
        .auth-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem; font-weight: 900; color: #fff;
            margin-bottom: .3rem;
        }
        .auth-subtitle { color: var(--muted); font-size: .85rem; }

        .auth-body { padding: 2rem; }

        /* Form fields */
        .field-group { margin-bottom: 1.2rem; }
        .field-label {
            display: block; font-size: .75rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 1.5px;
            color: var(--muted); margin-bottom: .5rem;
        }
        .field-input {
            width: 100%;
            background: var(--dark2);
            border: 1px solid var(--border2);
            border-radius: 8px;
            color: var(--text);
            font-size: .92rem;
            padding: .72rem 1rem;
            font-family: 'DM Sans', sans-serif;
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }
        .field-input:focus {
            border-color: rgba(201,168,76,.5);
            box-shadow: 0 0 0 3px rgba(201,168,76,.08);
        }
        .field-input::placeholder { color: var(--muted); }

        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, var(--gold), var(--gold-lt));
            color: #08080e; font-weight: 700; border: none;
            padding: .82rem; border-radius: 8px; font-size: .95rem;
            font-family: 'DM Sans', sans-serif; letter-spacing: .4px;
            cursor: pointer; transition: opacity .2s, transform .15s;
            margin-top: .5rem;
        }
        .btn-submit:hover { opacity: .85; transform: translateY(-1px); }

        .auth-footer {
            text-align: center; padding: 1.2rem 2rem;
            border-top: 1px solid var(--border2);
            font-size: .83rem; color: var(--muted);
        }
        .auth-footer a { color: var(--gold); text-decoration: none; font-weight: 600; }
        .auth-footer a:hover { text-decoration: underline; }

        .alert-error {
            background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25);
            color: #fca5a5; border-radius: 8px; padding: .75rem 1rem;
            font-size: .83rem; margin-bottom: 1.2rem;
            display: flex; align-items: center; gap: 8px;
        }
        .already-logged {
            background: rgba(34,197,94,.08); border: 1px solid rgba(34,197,94,.2);
            color: #86efac; border-radius: 8px; padding: .75rem 1rem;
            font-size: .83rem; margin-bottom: 1.2rem;
        }
        .already-logged a { color: #86efac; }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-wrap">
        <div class="auth-card">

            <div class="auth-header">
                <div class="auth-icon"><i class="fa fa-user"></i></div>
                <div class="auth-title">Connexion</div>
                <div class="auth-subtitle">Accédez à votre espace CinéMax</div>
            </div>

            <div class="auth-body">

                {% if error %}
                    <div class="alert-error">
                        <i class="fa fa-circle-xmark"></i>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="already-logged">
                        <i class="fa fa-circle-check me-2"></i>
                        Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>
                        — <a href="{{ logout_path() }}">Se déconnecter</a>
                    </div>
                {% endif %}

                <form method="post">

                    <div class="field-group">
                        <label class="field-label" for="inputEmail">
                            <i class="fa fa-envelope me-1"></i> Adresse email
                        </label>
                        <input type="email"
                               value="{{ last_username }}"
                               name="email"
                               id="inputEmail"
                               class="field-input"
                               autocomplete="email"
                               placeholder="exemple@email.com"
                               required autofocus>
                    </div>

                    <div class="field-group">
                        <label class="field-label" for="inputPassword">
                            <i class="fa fa-lock me-1"></i> Mot de passe
                        </label>
                        <input type="password"
                               name="password"
                               id="inputPassword"
                               class="field-input"
                               autocomplete="current-password"
                               placeholder="••••••••"
                               required>
                    </div>

                    <input type="hidden" name="_csrf_token"
                           data-controller="csrf-protection"
                           value="{{ csrf_token('authenticate') }}">

                    <button class="btn-submit" type="submit">
                        <i class="fa fa-right-to-bracket me-2"></i> Se connecter
                    </button>

                </form>
            </div>

            <div class="auth-footer">
                Pas encore de compte ?
                <a href="{{ path('app_register') }}">Créer un compte</a>
            </div>

        </div>
    </div>
{% endblock %}
