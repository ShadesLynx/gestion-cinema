{% extends 'base.html.twig' %}

{% block title %}Inscription — CinéMax{% endblock %}

{% block extra_css %}
    <style>
        .auth-wrap {
            min-height: 100vh;
            width: 100%;
            display: flex;
            align-items: center;    /* Vertical center */
            justify-content: center; /* Horizontal center */
            box-sizing: border-box;
            /* Remove any left, right, or position:relative here */
        }

        .auth-card {
            background: var(--card);
            border: 1px solid var(--border2);
            border-radius: 16px;
            width: 100%;
            max-width: 440px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,.6);
            /* Ensure no margins are pushing it */
            margin: 0 auto;
        }
        .auth-header {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 2.5rem 2rem 2rem;
            text-align: center;
            border-bottom: 1px solid var(--border2);
        }
        .auth-icon {
            width: 56px; height: 56px; border-radius: 50%;
            background: linear-gradient(135deg, var(--gold), var(--gold-lt));
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1rem; font-size: 1.3rem; color: #08080e;
        }
        .auth-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem; font-weight: 900; color: #fff; margin-bottom: .3rem;
        }
        .auth-subtitle { color: var(--muted); font-size: .85rem; }

        .auth-body { padding: 2rem; }

        /* Override Symfony form widget styles */
        .auth-body .form-group,
        .auth-body div { margin-bottom: 0; }

        /* Target Symfony-generated form rows */
        .field-wrap { margin-bottom: 1.2rem; }
        .field-wrap label {
            display: block; font-size: .75rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 1.5px;
            color: var(--muted); margin-bottom: .5rem;
        }
        .field-wrap input[type="text"],
        .field-wrap input[type="email"],
        .field-wrap input[type="password"] {
            width: 100%;
            background: var(--dark2);
            border: 1px solid var(--border2);
            border-radius: 8px;
            color: var(--text);
            font-size: .92rem;
            padding: .72rem 1rem;
            font-family: 'DM Sans', sans-serif;
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }
        .field-wrap input:focus {
            border-color: rgba(201,168,76,.5);
            box-shadow: 0 0 0 3px rgba(201,168,76,.08);
        }
        .field-wrap input::placeholder { color: var(--muted); }

        /* Checkbox (agreeTerms) */
        .checkbox-wrap {
            display: flex; align-items: flex-start; gap: 10px;
            margin-bottom: 1.5rem;
        }
        .checkbox-wrap input[type="checkbox"] {
            width: 18px; height: 18px; margin-top: 2px; flex-shrink: 0;
            accent-color: var(--gold); cursor: pointer;
        }
        .checkbox-wrap label {
            font-size: .83rem; color: var(--muted); cursor: pointer; line-height: 1.5;
        }

        /* Errors */
        .form-errors, .invalid-feedback, ul.form-error {
            color: #fca5a5; font-size: .78rem; margin-top: .3rem; list-style: none; padding: 0;
        }
        .global-error {
            background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25);
            color: #fca5a5; border-radius: 8px; padding: .75rem 1rem;
            font-size: .83rem; margin-bottom: 1.2rem;
        }

        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, var(--gold), var(--gold-lt));
            color: #08080e; font-weight: 700; border: none;
            padding: .82rem; border-radius: 8px; font-size: .95rem;
            font-family: 'DM Sans', sans-serif; letter-spacing: .4px;
            cursor: pointer; transition: opacity .2s, transform .15s;
        }
        .btn-submit:hover { opacity: .85; transform: translateY(-1px); }

        .auth-footer {
            text-align: center; padding: 1.2rem 2rem;
            border-top: 1px solid var(--border2);
            font-size: .83rem; color: var(--muted);
        }
        .auth-footer a { color: var(--gold); text-decoration: none; font-weight: 600; }
        .auth-footer a:hover { text-decoration: underline; }
    </style>
{% endblock %}

{% block body %}
    <div class="auth-wrap">
        <div class="auth-card">

            <div class="auth-header">
                <div class="auth-icon"><i class="fa fa-user-plus"></i></div>
                <div class="auth-title">Créer un compte</div>
                <div class="auth-subtitle">Rejoignez CinéMax et réservez vos séances</div>
            </div>

            <div class="auth-body">

                {{ form_errors(registrationForm) }}

                {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}

                {# ── Nom ── #}
                {% if registrationForm.nom is defined %}
                    <div class="field-wrap">
                        <label>
                            <i class="fa fa-user me-1"></i> Nom
                        </label>
                        {{ form_widget(registrationForm.nom, {
                            'attr': {'placeholder': 'Votre nom', 'class': ''}
                        }) }}
                        {{ form_errors(registrationForm.nom) }}
                    </div>
                {% endif %}

                {# ── Prénom ── #}
                {% if registrationForm.prenom is defined %}
                    <div class="field-wrap">
                        <label>
                            <i class="fa fa-user me-1"></i> Prénom
                        </label>
                        {{ form_widget(registrationForm.prenom, {
                            'attr': {'placeholder': 'Votre prénom', 'class': ''}
                        }) }}
                        {{ form_errors(registrationForm.prenom) }}
                    </div>
                {% endif %}

                {# ── Email ── #}
                <div class="field-wrap">
                    <label>
                        <i class="fa fa-envelope me-1"></i> Adresse email
                    </label>
                    {{ form_widget(registrationForm.email, {
                        'attr': {'placeholder': 'exemple@email.com', 'class': ''}
                    }) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                {# ── Password ── #}
                <div class="field-wrap">
                    <label>
                        <i class="fa fa-lock me-1"></i> Mot de passe
                    </label>
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {'placeholder': '••••••••', 'class': ''}
                    }) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                {# ── Agree Terms ── #}
                {% if registrationForm.agreeTerms is defined %}
                    <div class="checkbox-wrap">
                        {{ form_widget(registrationForm.agreeTerms) }}
                        <label for="{{ registrationForm.agreeTerms.vars.id }}">
                            J'accepte les conditions d'utilisation de CinéMax
                        </label>
                    </div>
                    {{ form_errors(registrationForm.agreeTerms) }}
                {% endif %}

                <button type="submit" class="btn-submit">
                    <i class="fa fa-user-plus me-2"></i> Créer mon compte
                </button>

                {{ form_end(registrationForm) }}

            </div>

            <div class="auth-footer">
                Déjà inscrit ?
                <a href="{{ path('app_login') }}">Se connecter</a>
            </div>

        </div>
    </div>
{% endblock %}
