{% extends "@EasyAdmin/layout.html.twig" %}

{% block content_title %}<h1>Cinema Admin Dashboard 🎬</h1>{% endblock %}

{% block content %}
    <div class="admin-dashboard">
        <div class="stats-container" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 30px;">
            
            <div class="stat-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                <div style="font-size: 12px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Films</div>
                <div style="font-size: 32px; font-weight: bold; margin-top: 10px;">{{ filmsCount }}</div>
                <div style="font-size: 12px; margin-top: 10px; opacity: 0.8;">Total films in catalog</div>
            </div>

            <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                <div style="font-size: 12px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Projections</div>
                <div style="font-size: 32px; font-weight: bold; margin-top: 10px;">{{ projectionsCount }}</div>
                <div style="font-size: 12px; margin-top: 10px; opacity: 0.8;">Scheduled screenings</div>
            </div>

            <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                <div style="font-size: 12px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Reservations</div>
                <div style="font-size: 32px; font-weight: bold; margin-top: 10px;">{{ reservationsCount }}</div>
                <div style="font-size: 12px; margin-top: 10px; opacity: 0.8;">Active reservations</div>
            </div>

            <div class="stat-card" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                <div style="font-size: 12px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Users</div>
                <div style="font-size: 32px; font-weight: bold; margin-top: 10px;">{{ usersCount }}</div>
                <div style="font-size: 12px; margin-top: 10px; opacity: 0.8;">Registered users</div>
            </div>

        </div>
    </div>
{% endblock %}
