{% extends 'base.html.twig' %}

{% block title %}Réserver — {{ projection.film.titre }}{% endblock %}

{% block extra_css %}
    <style>
        .res-wrap { max-width: 620px; margin: 3rem auto; padding: 0 1rem; }
        .back-link {
            display: inline-flex; align-items: center; gap: 7px;
            color: var(--muted); text-decoration: none; font-size: .82rem;
            margin-bottom: 1.5rem; transition: color .2s;
        }
        .back-link:hover { color: var(--gold); }
        .res-card {
            background: var(--card); border: 1px solid var(--border2);
            border-radius: 14px; overflow: hidden;
            box-shadow: 0 30px 80px rgba(0,0,0,.5);
        }
        .res-header {
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            padding: 1.8rem 2rem; border-bottom: 1px solid var(--border2);
        }
        .res-genre {
            display: inline-block; border: 1px solid var(--border); color: var(--gold);
            font-size: .62rem; letter-spacing: 2px; text-transform: uppercase;
            padding: .22rem .7rem; border-radius: 2px; font-weight: 600; margin-bottom: .6rem;
        }
        .res-film-title {
            font-family: 'Playfair Display', serif; font-size: 1.6rem;
            font-weight: 900; color: #fff; margin-bottom: .8rem;
        }
        .res-chips { display: flex; flex-wrap: wrap; gap: .5rem; }
        .res-chip {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(255,255,255,.05); border: 1px solid var(--border2);
            border-radius: 20px; font-size: .75rem; color: var(--muted); padding: .25rem .8rem;
        }
        .res-chip i { color: var(--gold); }
        .places-ok   { color: #86efac !important; border-color: rgba(34,197,94,.3) !important; }
        .places-low  { color: #fde047 !important; border-color: rgba(234,179,8,.3) !important; }

        /* Body */
        .res-body { padding: 2rem; }
        .res-section-title {
            font-size: .7rem; text-transform: uppercase; letter-spacing: 2px;
            color: var(--gold); font-weight: 600; margin-bottom: 1rem;
            padding-bottom: .6rem; border-bottom: 1px solid var(--border2);
        }
        .user-box {
            background: rgba(201,168,76,.05); border: 1px solid var(--border);
            border-radius: 8px; padding: 1rem 1.2rem; margin-bottom: 1.5rem;
            display: flex; align-items: center; gap: 1rem;
        }
        .user-avatar {
            width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
            background: linear-gradient(135deg, var(--gold), var(--gold-lt));
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 1rem; color: #08080e;
        }
        .user-name { font-weight: 600; color: var(--text); font-size: .95rem; }
        .user-email { font-size: .78rem; color: var(--muted); }
        .summary-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: .6rem 0; border-bottom: 1px solid rgba(255,255,255,.04);
            font-size: .88rem;
        }
        .summary-row:last-child { border-bottom: none; }
        .summary-row .lbl { color: var(--muted); }
        .summary-row .val { font-weight: 500; color: var(--text); text-align: right; }
        .status-badge {
            background: rgba(234,179,8,.1); border: 1px solid rgba(234,179,8,.25);
            color: #fde047; font-size: .75rem; padding: .2rem .7rem; border-radius: 20px;
        }
        .btn-confirm {
            display: block; width: 100%; background: linear-gradient(135deg, var(--gold), var(--gold-lt));
            color: #08080e; font-weight: 700; border: none; padding: .85rem;
            border-radius: 8px; font-size: 1rem; letter-spacing: .4px;
            cursor: pointer; transition: opacity .2s, transform .15s; margin-top: 1.5rem;
        }
        .btn-confirm:hover { opacity: .85; transform: translateY(-1px); }
    </style>
{% endblock %}

{% block body %}
    <div class="res-wrap">
        <a href="{{ path('app_film_show', {'id': projection.film.id}) }}" class="back-link">
            <i class="fa fa-arrow-left"></i> Retour au film
        </a>

        <div class="res-card">

            {# ── Header: Film + Projection info from DB ── #}
            <div class="res-header">
                {% if projection.film.genre %}
                    <div class="res-genre">{{ projection.film.genre }}</div>
                {% endif %}
                <div class="res-film-title">{{ projection.film.titre }}</div>

                <div class="res-chips">
                    {# Real dateProjection from DB #}
                    <div class="res-chip">
                        <i class="fa fa-clock"></i>
                        {{ projection.dateProjection ? projection.dateProjection|date('d/m/Y à H:i') : '—' }}
                    </div>
                    {# Real salle from DB #}
                    <div class="res-chip">
                        <i class="fa fa-door-open"></i>
                        Salle {{ projection.salle }}
                    </div>
                    {# Real nbrPlaces from DB #}
                    <div class="res-chip {{ projection.nbPlaces > 5 ? 'places-ok' : 'places-low' }}">
                        <i class="fa fa-chair"></i>
                        {{ projection.nbPlaces }} place{{ projection.nbPlaces != 1 ? 's' : '' }} restante{{ projection.nbPlaces != 1 ? 's' : '' }}
                    </div>
                </div>
            </div>

            <div class="res-body">

                {# ── User info from session ── #}
                <div class="res-section-title"><i class="fa fa-user me-2"></i>Vos informations</div>
                <div class="user-box">
                    <div class="user-avatar">
                        {{ app.user.prenom|slice(0,1)|upper }}
                    </div>
                    <div>
                        {# Real user data from DB #}
                        <div class="user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                        <div class="user-email">{{ app.user.email }}</div>
                    </div>
                </div>

                {# ── Summary ── #}
                <div class="res-section-title"><i class="fa fa-receipt me-2"></i>Récapitulatif</div>
                <div class="mb-3">
                    <div class="summary-row">
                        <span class="lbl">Film</span>
                        <span class="val">{{ projection.film.titre }}</span>
                    </div>
                    <div class="summary-row">
                        <span class="lbl">Date & heure</span>
                        <span class="val">{{ projection.dateProjection ? projection.dateProjection|date('d/m/Y à H:i') : '—' }}</span>
                    </div>
                    <div class="summary-row">
                        <span class="lbl">Salle</span>
                        <span class="val">{{ projection.salle }}</span>
                    </div>
                    <div class="summary-row">
                        <span class="lbl">Statut initial</span>
                        <span class="val"><span class="status-badge">En attente</span></span>
                    </div>
                </div>

                {# ── Symfony form — just a confirm button ── #}
                {{ form_start(form) }}
                <button type="submit" class="btn-confirm">
                    <i class="fa fa-ticket me-2"></i> Confirmer la réservation
                </button>
                {{ form_end(form) }}

            </div>
        </div>
    </div>
{% endblock %}
